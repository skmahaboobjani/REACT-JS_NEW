import React, { useState } from "react";
function App() {
  const [count, setcount] = useState(0);
  let increment = () => {
    setcount(count + 1);
    setcount(count + 1);
    setcount(count + 1);
    setcount(count + 1);
  };
  return (
    <div>
      <h1>counter question</h1>
      {count}
      <br />
      <button onClick={increment}> increment</button>
    </div>
  );
}

export default App;
